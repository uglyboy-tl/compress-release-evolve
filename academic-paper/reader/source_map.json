  "glossary": {
    "entropy": {
      "en": "A measure of randomness or uncertainty in a system",
      "zh": "系统中随机性或不确定性的度量"
    },
    "control": {
      "en": "The process of transporting randomness across dimensions",
      "zh": "将随机性跨维度传输的过程"
    },
    "compression mapping": {
      "en": "A function f: X → Y where |Y| < |X|",
      "zh": "一个函数 f: X → Y，其中 |Y| < |X|"
    },
    "antifragility": {
      "en": "The ability to gain from randomness and disorder",
      "zh": "从随机性和混乱中获益的能力"
    },
    "coding": {
      "en": "The formal expression of control rules",
      "zh": "控制规则的形式化表达"
    },
    "coding-evolution cycle": {
      "en": "The cycle of entropy decrease → entropy increase → new entropy decrease",
      "zh": "熵减少→熵增加→新熵减少的循环"
    }
  }
}